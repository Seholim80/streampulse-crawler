{
  "name": "streampulse-crawler",
  "version": "1.0.0",
  "description": "StreamPulse 데이터 수집기 - Chzzk & SOOP API Crawler",
  "type": "module",
  "scripts": {
    "collect": "tsx src/index.ts",
